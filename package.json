{
  "name": "event-graph",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "seed": "tsx src/seed.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "build": "tsc --noEmit",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "dev:all": "concurrently -k -n api,web -c blue,magenta \"npm run dev\" \"npm run dev --prefix web\""
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "express": "^5.0.1",
    "pg": "^8.13.1",
    "pg-copy-streams": "^6.0.6",
    "uuidv7": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "@types/pg-copy-streams": "^1.2.5",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "testcontainers": "^12.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.9"
  }
}
